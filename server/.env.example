PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/rentlandlord
JWT_SECRET=change-me-to-a-long-random-string

# CORS: Next.js dev server
CLIENT_ORIGIN=http://localhost:3000

# Email (Gmail app password, SendGrid SMTP, or Ethereal for dev)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="RentLandlord <noreply@example.com>"

# Azure Blob (optional — leave empty to skip upload in dev)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=rent-documents
